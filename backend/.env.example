PORT=5000
NODE_ENV=development

# Supabase PostgreSQL (Session pooler — IPv4)
# Reemplazá [YOUR-PASSWORD] con la contraseña de tu proyecto en Supabase → Settings → Database
DATABASE_URL=postgresql://postgres.vdblqxmwbhtwlwckvila:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# Alternativa sin connection string:
# DB_HOST=aws-1-us-east-2.pooler.supabase.com
# DB_PORT=5432
# DB_USER=postgres.vdblqxmwbhtwlwckvila
# DB_PASSWORD=[YOUR-PASSWORD]
# DB_NAME=postgres
# DB_SSL=true

JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:1748

# Mercado Pago (futuro)
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_PUBLIC_KEY=
