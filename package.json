{
  "name": "focustech",
  "version": "1.0.0",
  "private": true,
  "description": "Focus Tech e-commerce — frontend + backend",
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c blue,magenta \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "start": "npm run start --prefix backend",
    "build": "npm run build --prefix frontend",
    "db:schema": "npm run db:schema --prefix backend",
    "db:seed": "npm run db:seed --prefix backend",
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0"
  }
}
